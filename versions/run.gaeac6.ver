#!/usr/bin/env bash
export stack_compiler=intel
export stack_compiler_ver=2023.2.0

export stack_mpi=cray-mpich
export stack_mpi_ver=8.1.30

spack_stack_root="/ncrc/proj/epic/spack-stack/c6"


source "${HOMEgfs:-}/versions/spack.ver"

# Gaea uses a slgihtly older version of cdo
export cdo_ver=2.3.0

export perl_ver=5.38.2

export hsi_mod_path="/usw/hpss/modulefiles"
export hsi_ver=9.3
