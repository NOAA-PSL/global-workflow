gdas_restarta:
    {% set head = "gdas.t" + cycle_HH + "z." %}
    name: "GDAS_RESTARTA"
    target: "{{ ATARDIR }}/{{ cycle_YMDH }}/gdas_restarta.tar"
    optional:
        # Deterministic analysis increments
        {% if DO_JEDIATMVAR and not (ATMINC_GRID == 'gaussian') %}
            {% for iaufhr in iaufhrs_str %}
                {% for itile in range(6) %}
        - "{{ COMIN_ATMOS_ANALYSIS }}/{{ head }}jedi_increment.atm.i{{ iaufhr }}.tile{{ itile+1 }}.nc"
                {% endfor %}
            {% endfor %}
        {% else %}
        # IAU increments
            {% for iaufhr in iaufhrs_str %}
        - "{{ COMIN_ATMOS_ANALYSIS }}/{{ head }}increment.atm.i{{ iaufhr }}.nc"
            {% endfor %}
        {% endif %}

        # Soil DA increments
        {% if DO_GSISOILDA %}
            {% if DO_LAND_IAU %}    #regridded tiles for land iau
                {% for itile in range(1,7) %}
        - "{{ COMIN_ATMOS_ANALYSIS }}/increment.sfc.tile{{ itile }}.nc"
                {% endfor %}
            {% endif %}
        {% endif %}

        # Surface analysis tiles
        # anl_time_YMD and anl_time_HH are pre-calculated in Python: -3H if DOHYBVAR and DOIAU, 0H otherwise
        {% for itile in range(1,7) %}
        - "{{ COMIN_ATMOS_RESTART }}/{{ anl_time_YMD }}.{{ anl_time_HH }}0000.sfcanl_data.tile{{ itile }}.nc"
        {% endfor %}

        # Initial biases
        {% if not DO_JEDIATMVAR %}
        {% for suffix in [
            'abias.txt',
            'abias_air.txt',
            'abias_pc.txt',
            'cnvstat.tar',
            'abias_int.txt',
            'increment.dtf.i006.nc',
            'analysis.done.txt'
        ] %}
        - "{{ COMIN_ATMOS_ANALYSIS }}/{{ head }}{{ suffix }}"
        {% endfor %}
        {% else %}
        - "{{ COMIN_ATMOS_ANALYSIS }}/{{ head }}varbc_params.tar"
        {% endif %}

        # Input BUFR files
        {% for suffix in ['prepbufr', 'prepbufr.acft_profiles'] %}
        - "{{ COMIN_OBS }}/{{ head }}{{ suffix }}"
        {% endfor %}
        - "{{ COMIN_ATMOS_ANALYSIS }}/{{ head }}radstat.tar"
