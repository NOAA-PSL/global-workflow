gfswave:
    {% set head = "gfs.t" + cycle_HH + "z." %}

    name: "GFSWAVE"
    target: "{{ ATARDIR }}/{{ cycle_YMDH }}/gfswave.tar"
    optional:
        # Wave GRIB2 regional forecast products
        {% for file_path in WAVE_GRID_RES_COM_list %}
            {% for fh in range(0, FHMAX_HF_WAV + FHOUT_HF_WAV, FHOUT_HF_WAV) %}
        - "{{ file_path }}/{{ head }}*.*.f{{ '%03d' % fh }}.grib2"
        - "{{ file_path }}/{{ head }}*.*.f{{ '%03d' % fh }}.grib2.idx"
            {% endfor %}
            # Global wave GRIB2 forecast products
            {% for fh in range(FHMAX_HF_WAV + FHOUT_WAV_GFS, FHMAX_WAV_GFS + FHOUT_WAV_GFS, FHOUT_WAV_GFS) %}
        - "{{ file_path }}/{{ head }}*.*.f{{ '%03d' % fh }}.grib2"
        - "{{ file_path }}/{{ head }}*.*.f{{ '%03d' % fh }}.grib2.idx"
            {% endfor %}
        {% endfor %}

        # Wave point output
        - "{{ COMIN_WAVE_STATION }}/{{ head }}bull.tar"
        - "{{ COMIN_WAVE_STATION }}/{{ head }}cbull.tar"
        - "{{ COMIN_WAVE_STATION }}/{{ head }}spec.tar.gz"

        # Wave boundary point output
        {% if DOBNDPNT_WAVE %}
        - "{{ COMIN_WAVE_STATION }}/{{ head }}ibpbull.tar"
        - "{{ COMIN_WAVE_STATION }}/{{ head }}ibpcbull.tar"
        - "{{ COMIN_WAVE_STATION }}/{{ head }}ibp.tar"
        {% endif %}
