wave:
    mkdir:
        {% for mem in range(first_mem, last_mem + 1) %}
        {% set imem = mem - first_mem %}
        {% set COMOUT_WAVE_RESTART_PREV_MEM = COMOUT_WAVE_RESTART_PREV_MEM_list[imem] %}
        - "{{ COMOUT_WAVE_RESTART_PREV_MEM }}"
        {% endfor %} # mem loop
    link_req:
        {% for mem in range(first_mem, last_mem + 1) %}
        {% set imem = mem - first_mem %}
        {% set COMOUT_WAVE_RESTART_PREV_MEM = COMOUT_WAVE_RESTART_PREV_MEM_list[imem] %}
        {% set ww3_file = ICSDIR ~ "/" ~ COMOUT_WAVE_RESTART_PREV_MEM | relpath(ROTDIR) ~ "/" ~ m_prefix ~ ".restart.ww3" %}
        {% if path_exists(ww3_file ~ ".nc") %} 
        - ["{{ ww3_file }}.nc" , "{{ COMOUT_WAVE_RESTART_PREV_MEM }}/{{ m_prefix }}.restart.ww3.nc"]
        {% else %}
            {% if path_exists(ww3_file) %}
        - ["{{ ww3_file }}" , "{{ COMOUT_WAVE_RESTART_PREV_MEM }}/{{ m_prefix }}.restart.ww3"]
            {% endif %}
        {% endif %}
        {% endfor %} # mem loop
