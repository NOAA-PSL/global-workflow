ocean_control_RT:
    mkdir:
        - "{{ COMOUT_OCEAN_RESTART_PREV }}"
        - "{{ COMOUT_OCEAN_ANALYSIS }}"
    link_req:
        {% set restart_path = ICSDIR ~ '/' ~ 'gdas.' ~ previous_cycle_YMD ~ '/' ~ previous_cycle_HH ~ '/model/ocean/restart/' ~ previous_cycle_YMD ~ '.' ~ mid_cyc ~ '0000.' %}
        {% set increment_file = ICSDIR ~ '/' ~ 'gfs.' ~ current_cycle_YMD ~ '/' ~ current_cycle_HH ~ '/analysis/ocean/gfs.t' ~ current_cycle_HH ~ 'z.ocninc.nc' %}

        # Restart increment files
        {% for ftype in ["MOM.res.nc", "MOM.res_1.nc", "MOM.res_2.nc", "MOM.res_3.nc"] %}
            {% set file = restart_path ~ ftype %}
        - ["{{ file }}", "{{ COMOUT_OCEAN_RESTART_PREV }}"]
        {% endfor %}
        # Include increment files
        - ["{{ increment_file }}", "{{ COMOUT_OCEAN_ANALYSIS }}"]
