ice:
    {% if START_ICE_FROM_ANA == True %}
    mkdir:
        - "{{ COMOUT_ICE_ANALYSIS }}"
    link_req:
        - ["{{ ICSDIR }}/{{ COMOUT_ICE_ANALYSIS | relpath(ROTDIR) }}/{{ m_prefix }}.analysis.cice_model.res.nc", "{{ COMOUT_ICE_ANALYSIS }}"]
    {% else %}
    mkdir:
        - "{{ COMOUT_ICE_RESTART_PREV }}"
    link_req:
        - ["{{ ICSDIR }}/{{ COMOUT_ICE_RESTART_PREV | relpath(ROTDIR) }}/{{ m_prefix }}.cice_model.res.nc", "{{ COMOUT_ICE_RESTART_PREV }}"]
    {% endif %}
