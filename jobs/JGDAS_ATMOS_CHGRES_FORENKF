#! /usr/bin/env bash

source "${HOMEgfs}/ush/jjob_header.sh" -e "anal" -c "base anal echgres"

##############################################
# Set variables used in the script
##############################################
export DO_CALC_ANALYSIS=${DO_CALC_ANALYSIS:-"YES"}

##############################################
# Begin JOB SPECIFIC work
##############################################

export APREFIX="${RUN/enkf/}.t${cyc}z."
export APREFIX_ENS="${RUN}.t${cyc}z."

RUN=${RUN/enkf/} YMD=${PDY} HH=${cyc} declare_from_tmpl -rx \
    COMIN_ATMOS_HISTORY:COM_ATMOS_HISTORY_TMPL \
    COMOUT_ATMOS_HISTORY:COM_ATMOS_HISTORY_TMPL

MEMDIR="mem001" YMD=${PDY} HH=${cyc} declare_from_tmpl -rx \
    COMIN_ATMOS_HISTORY_MEM:COM_ATMOS_HISTORY_TMPL

###############################################################
# Run relevant script
${CHGRESFCSTSH:-${SCRgfs}/exgdas_atmos_chgres_forenkf.sh} && true
export err=$?
if [[ ${err} -ne 0 ]]; then
    err_exit
fi

##############################################
# End JOB SPECIFIC work
##############################################

##############################################
# Final processing
##############################################
if [[ -e "${pgmout}" ]]; then
    cat "${pgmout}"
fi

##########################################
# Remove the Temporary working directory
##########################################
cd "${DATAROOT}" || true
if [[ "${KEEPDATA}" == "NO" ]]; then
    rm -rf "${DATA}"
fi

exit 0
