#!/usr/bin/bash

export GFS_CI_ROOT=/lfs/h2/emc/global/noscrub/globalworkflow.ci/GFS_CI_ROOT
export ICSDIR_ROOT=/lfs/h2/emc/global/noscrub/emc.global/data/ICSDIR
# HPC account which overides the default account
export HPC_ACCOUNT=${HPC_ACCOUNT:-GFS-DEV}

#########################################################################
# GitLab CI configuration
# These variables are referenced directly by launch_gitlab_runner.sh
#########################################################################

# TODO: Populate GitLab CI variables for WCOSS2 when runners are deployed
# export GITLAB_URL=https://vlab.noaa.gov/gitlab-community
# export GITLAB_RUNNER_NAME="WCOSS2"
# export GITLAB_BUILDS_DIR=${GFS_CI_ROOT}/BUILDS/GITLAB
# export GITLAB_RUNNER_DIR="${GFS_CI_ROOT}/GitLab/Runner"

# Port for GitLab Runner's embedded Prometheus metrics endpoint
# Used by launch_gitlab_runner.sh for liveness health checks
# Default: 9252 (IANA-allocated for GitLab Runner in Prometheus port registry)
# Bound to localhost only — not exposed to the network
export GITLAB_RUNNER_METRICS_PORT=9252

#########################################################################
# System-specific settings
# Platform-specific paths and utilities for CI/CD operations
#########################################################################

# Utilities path for custom builds and role account tools
# TODO: Populate with actual role account path for this machine
export GFS_CI_UTIL_PATH="/path/to/role/account/utils"

# Custom Rocoto build path for testing
# used for CI jobs requiring Rocoto with dry_run support
# export GFS_CI_ROCOTO_PATH="${GFS_CI_UTIL_PATH}/rocoto_dryrun_nodaemon/bin"
unset GFS_CI_ROCOTO_PATH
export max_concurrent_cases=5
export max_concurrent_pr=4
