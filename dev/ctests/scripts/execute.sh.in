#!/usr/bin/env bash

set -xe

HOMEglobal="@PROJECT_SOURCE_DIR@"
TEST_NAME=${1:?"Name of the test is required"}
TEST_NAME=$("${HOMEglobal}/dev/ci/scripts/utils/ci_utils.sh" get_pslot "@CMAKE_CURRENT_BINARY_DIR@/RUNTESTS" "${TEST_NAME}")
JOB=${2:?"Job name is required"}
idate=$3

CASEDIR="@CMAKE_CURRENT_BINARY_DIR@/RUNTESTS/EXPDIR/${TEST_NAME}"
cd "${CASEDIR}"
rm -f ./*.db
rm -f ./jobcard

# Clean up any existing DATAROOT to avoid data clashes on repeated runs
# Extract STMP from config.base (same technique as generate_workflows.sh)
if [[ -f "${CASEDIR}/config.base" ]]; then
    _dataroot=$(
        PDY=0 cyc=0 source "${CASEDIR}/config.base" > /dev/null 2>&1 || true
        echo "${STMP:-}/RUNDIRS/${TEST_NAME}"
    )
    if [[ -n "${_dataroot}" && -d "${_dataroot}" ]]; then
        echo "Removing existing DATAROOT: ${_dataroot}"
        rm -rf "${_dataroot}"
    fi
fi

# Use custom Rocoto build with dryrun feature for testing
# When GFS_CI_ROCOTO_PATH is unset, the system Rocoto will be used

source "${HOMEglobal}/ush/detect_machine.sh"
source "${HOMEglobal}/dev/ci/platforms/config.${MACHINE_ID}"

if [[ -x "${GFS_CI_ROCOTO_PATH}/rocotoboot" ]]; then
    yes | "${GFS_CI_ROCOTO_PATH}/rocotoboot" --dryrun -d "${TEST_NAME}.db" -w "${TEST_NAME}.xml" -v 10 -c "${idate}00" -t "${JOB}" 2> jobcard || true
    # Rocoto outputs the job card inside of {{}}.  Strip all other output to get just the job card.
    sed -n '/^{{/,/^}}/p' < jobcard | sed '1d;$d'  > "${TEST_NAME}.sub" || true
else
    echo "ERROR: Custom Rocoto build with dryrun feature not found at ${GFS_CI_ROCOTO_PATH}."
    exit 1
fi

#TODO - Generalize for batch system (hard coded to slurm)
output=$(sbatch "${TEST_NAME}.sub")
job_id=$(echo "${output}" | awk '{print $4}')
echo "Job ${job_id} submitted for test ${TEST_NAME} with job name ${JOB}"

# First loop: wait until job appears
lack_of_job_count=0
LACK_OF_JOB_LIMIT=5

while true; do
    job_status=$(sacct -j "${job_id}" --format=State --noheader -n | head -1 | tr -cd '[:alpha:]' | xargs) || true
    if [[ -n "${job_status}" ]]; then
        echo "Job ${job_id} found in sacct."
        break
    fi
    echo "Job ${job_id} not in sacct yet, attempt ${lack_of_job_count}/${LACK_OF_JOB_LIMIT}."
    lack_of_job_count=$((lack_of_job_count + 1))
    if [[ "${lack_of_job_count}" -ge "${LACK_OF_JOB_LIMIT}" ]]; then
        echo "Job ${job_id} not found after ${lack_of_job_count} attempts. Exiting."
        exit 1
    fi
    sleep 30
done

# Second loop: monitor job status until completion or failure
timeout=0
TIMEOUT=120
while true; do
    job_status=$(sacct -j "${job_id}" --format=State --noheader -n | head -1 | tr -cd '[:alpha:]' | xargs) || true
    if [[ "${job_status}" == "COMPLETED" ]]; then
        echo "Job ${job_id} completed successfully."
        break
    elif [[ "${job_status}" =~ ^(FAILED|CANCELLED|TIMEOUT)$ ]]; then
        echo "Job ${job_id} failed with status: ${job_status}."
        exit 1
    else
        echo "Job ${job_id} is still running with status: ${job_status}."
        sleep 60
        timeout=$((timeout + 1))
        if [[ "${timeout}" -gt "${TIMEOUT}" ]]; then
            echo "Job ${job_id} has been running for more than ${TIMEOUT} minutes. Exiting."
            exit 1
        fi
    fi
done
