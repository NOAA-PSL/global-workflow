#!/usr/bin/env bash

set -ux

TEST_NAME=${1:?"Name of the test is required"}
YAML_FILE=${2:?"Name of the CI yaml file for the test"}

# CMake to fill these variables
HOMEglobal="@PROJECT_SOURCE_DIR@"
RUNTESTS="@RUNTESTS@"
ICSDIR_ROOT="@ICSDIR_ROOT@"
HPC_ACCOUNT="@HPC_ACCOUNT@"

set +x
source "${HOMEglobal}/dev/ush/gw_setup.sh"
set -x

cd "${HOMEglobal}/dev/workflow" || exit 1

# We need to tag the pslot with the current git commit hash
# for a unique path in the RUNDIR directory for the use case
# where the same test is run multiple times from the same user
sha=$(git rev-parse --short HEAD)

pslot="${TEST_NAME}_${sha}" \
RUNTESTS="${RUNTESTS}" \
ICSDIR_ROOT="${ICSDIR_ROOT}" \
HPC_ACCOUNT="${HPC_ACCOUNT}" \
./create_experiment.py --yaml "${YAML_FILE}" --overwrite
rc=$?
if [[ "${rc}" -ne 0 ]]; then
    set +x
    echo "Failed to create test experiment for '${TEST_NAME}' with yaml file '${YAML_FILE}'"
    set -x
    exit "${rc}"
fi

exit 0
