#! /usr/bin/env bash

########## config.wavegempak ##########
# Wave steps specific

echo "BEGIN: config.wavegempak"

# Get task specific resources
source "${EXPDIR}/config.resources" wavegempak

export GEMPAK_GRIDS='aoc_9km gnh_10m gsh_15m'

# Maximum number of tasks for wavegempak
export MAX_TASKS=25

# Wave gempak output is every 3 hours till hour 72 and then every 6 hours till hour 180
export FHOUT_HF_WAV=3
export FHMAX_HF_WAV=72
export FHOUT_WAV=6
export FHOUT_WAV_GFS=${FHOUT_WAV}
if [[ ${FHMAX_GFS} -gt 180 ]]; then
  export FHMAX_GFS=180  # Note: This is the maximum forecast hour for GFS wave gempak output
fi

echo "END: config.wavegempak"
