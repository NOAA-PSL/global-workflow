#! /usr/bin/env bash
# shellcheck disable=SC2034

# GaeaC6-specific job resources

unset memory
unset "memory_${RUN}"
export FI_CXI_RX_MATCH_MODE=hybrid

case ${step} in
  "fcst" | "efcs")
    case "${CASE}" in
      "C768")
        export tasks_per_node=144
        ;;
      "C1152")
        export tasks_per_node=144
        ;;
      *)
        # Nothing to do for other resolutions
        true
        ;;
    esac
  ;;
  "eupd")
    # update ntasks to 80 and threads_per_task to 20
    case ${CASE} in
      "C768")
        export ntasks=480
        export threads_per_task=10
        export tasks_per_node=10
        ;;
      "C1152")
        export ntasks=480
        export threads_per_task=6
        export tasks_per_node=8
        ;;
      *)
        ;;
    esac
  ;;

  "anal")
    case ${CASE} in
      "C768")
        export threads_per_task=16
        ;;
      "C1152")
        export threads_per_task=16
        ;;
      *) 
        ;;
    esac
    if [[ "${CASE}" == "C768" || "${CASE}" == "C1152" ]]; then
        # Make ntasks a multiple of 16
        if [[ "${RUN}" == "gdas" ]]; then
            export ntasks=784
        elif [[ "${RUN}" == "gfs" ]]; then
            export ntasks=832
        fi
        export tasks_per_node=$(( max_tasks_per_node / threads_per_task ))
    fi
    ;;

  "atmanlvar" | "atmensanlobs" | "atmensanlsol")
    export tasks_per_node=48
    ;;

  "marinebmat")
    case ${OCNRES} in
      "025")
        tasks_per_node=$(( max_tasks_per_node / 4 )) 
        ;;
      *)
        ;;
    esac
    ;;

  "marineanlecen")
    case ${OCNRES} in
      "025")
        tasks_per_node=24
        ;;
      *)
        ;;
    esac
    ;;

  "wavepostbndpnt")
    walltime="01:30:00"
    ntasks=1
    threads_per_task=1
    tasks_per_node=$(( max_tasks_per_node / threads_per_task ))
    export is_exclusive=True
    NTASKS=${ntasks}
    ;;

  "wavepostbndpntbll")
    walltime="00:25:00"
    ntasks=2
    threads_per_task=1
    tasks_per_node=$(( max_tasks_per_node / threads_per_task ))
    export is_exclusive=True
    NTASKS=${ntasks}
    ;;

  "wavepostpnt")
    walltime="00:45:00"
    ntasks=3
    threads_per_task=1
    tasks_per_node=$(( max_tasks_per_node / threads_per_task ))
    export is_exclusive=True
    if [[ ${tasks_per_node} -gt 40 ]]; then
        tasks_per_node=40
        export is_exclusive=False
    fi
    NTASKS=${ntasks}
    ;;

  *) 
    ;;
esac
