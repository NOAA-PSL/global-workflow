#! /usr/bin/env bash

# Ursa-specific job resources

case ${step} in
  "fcst" | "efcs")
    case "${CASE}" in
      "C768")
        export tasks_per_node=144
        ;;
      "C1152")
        export tasks_per_node=144
        ;;
      "C96")
        if [[ "${RUN}" = "gcdas" ]]; then
          export walltime="01:30:00"
        fi	    
        ;;  
      *)
        # Nothing to do for other resolutions
        true
        ;;
    esac
  ;;
  "anal")
    case ${CASE} in
      "C768")
        export threads_per_task=8
        ;;
      "C1152")
        export threads_per_task=16
        ;;
      *)
        ;;
    esac
    if [[ "${CASE}" == "C768" || "${CASE}" == "C1152" ]]; then
        # Make ntasks a multiple of 16
        if [[ "${RUN}" == "gdas" ]]; then
            export ntasks=784
        elif [[ "${RUN}" == "gfs" ]]; then
            export ntasks=832
        fi
        export tasks_per_node=$(( max_tasks_per_node / threads_per_task ))
    fi
    ;;

  "eupd")
    case "${CASE}" in
      "C768")
        export ntasks=80
        export threads_per_task=20
        export tasks_per_node=$(( max_tasks_per_node / threads_per_task ))
        ;;
      "C1152")
        export ntasks=480
        export threads_per_task=6
        export tasks_per_node=8
        ;;
      *)
        ;;
    esac
    export tasks_per_node=$(( max_tasks_per_node / threads_per_task ))
    ;;

  "atmanlvar" | "atmensanlsol")
    export tasks_per_node=48
    ;;

  "atmensanlobs")
    export tasks_per_node=24
    export memory="240GB"
    ;;

  "aeroanlvar")
    export tasks_per_node=48
    ;;

  "marinebmat")
    case ${OCNRES} in
      "025")
        tasks_per_node=$(( max_tasks_per_node / 4 ))
        ;;
      *)
        ;;
    esac
    ;;

  "ocnanalecen")
    case ${OCNRES} in
      "025")
        ntasks=288
        tasks_per_node=12
        ;;
      *)
        ;;
    esac
    ;;
  *)
    ;;
esac
