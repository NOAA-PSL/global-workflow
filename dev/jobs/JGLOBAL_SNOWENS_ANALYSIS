#! /usr/bin/env bash
set -x

source "${HOMEglobal}/ush/jjob_header.sh" -e "esnowanl" -c "base esnowanl"

#{% if false %}
source "${HOMEglobal}/ush/jjob_standard_vars.sh"
#{% else %}
#{% include jjob_var_setup.j2 %}
#{% endif %}

source "${USHglobal}/jjob_shell_setup.sh"
# Set strict mode which will exit on error or undefined variable
# and exit on error in a pipeline (e.g. if a command in "cmd | cmd2" fails)
source "${USHglobal}/set_strict.sh"

##############################################
# Set variables used in the script
##############################################
# Setup Python path for pygfs
PYTHONPATH="${HOMEglobal}/ush/python${PYTHONPATH:+:${PYTHONPATH}}"
export PYTHONPATH

# Ignore possible spelling error (nothing is misspelled)
# shellcheck disable=SC2153
GDUMP="gdas"
export GDUMP
CDUMP=${RUN/enkf/}
export CDUMP

export NMEM_ENS_MAX=${NMEM_ENS}
if [[ "${RUN}" == "enkfgfs" ]]; then
    NMEM_ENS=${NMEM_ENS_GFS}
    export mem_offset=$((NMEM_ENS_GFS_OFFSET * cyc / assim_freq))
else
    export mem_offset=0
fi
##############################################
# Begin JOB SPECIFIC work
##############################################
# Generate COM variables from templates
declare -rx COMIN_OBS="${ROTDIR}/${CDUMP}.${PDY}/${cyc}/obs"
declare -rx COMOUT_ATMOS_ANALYSIS="${ROTDIR}/${RUN}.${PDY}/${cyc}/analysis/atmos"
declare -rx COMOUT_CONF="${ROTDIR}/${RUN}.${PDY}/${cyc}/conf"

for imem in $(seq 1 "${NMEM_ENS}"); do
    # Make the member COM directories. These will be declared in the script as we cycle through members.
    memchar="mem$(printf %03i "${imem}")"
    product_dir="${ROTDIR}/${RUN}.${PDY}/${cyc}/${memchar}/analysis/snow"
    mkdir -p "${product_dir}"
done

unset product_dir

declare -rx COMOUT_SNOW_ANALYSIS="${ROTDIR}/${RUN}.${PDY}/${cyc}/ensstat/analysis/snow"

mkdir -p "${COMOUT_SNOW_ANALYSIS}" "${COMOUT_CONF}"

###############################################################
# Run relevant script

EXSCRIPT=${SNOWANLPY:-${SCRglobal}/exglobal_snowens_analysis.py}
${EXSCRIPT} && true
export err=$?
if [[ ${err} -ne 0 ]]; then
    err_exit "Failed to caluclate the ensemble snow analysis"
fi

##############################################
# End JOB SPECIFIC work
##############################################

##############################################
# Final processing
##############################################
if [[ -e "${pgmout}" ]]; then
    cat "${pgmout}"
fi

##########################################
# Remove the Temporary working directory
##########################################
cd "${DATAROOT}" && true
export err=$?
if [[ ${err} -ne 0 ]]; then
    err_exit "Failed to change directory to DATAROOT!"
fi
if [[ "${KEEPDATA}" == "NO" ]]; then
    rm -rf "${DATA}"
fi

exit 0
